generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH + USERS
// ============================================================

enum UserRole {
  ADMIN
  MANAGER
  REP
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(REP)
  isActive     Boolean  @default(true)

  territories   UserTerritory[]
  importBatches ImportBatch[]
  auditLogs     AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserTerritory {
  id          String @id @default(cuid())
  userId      String
  territoryId String

  user      User      @relation(fields: [userId], references: [id])
  territory Territory @relation(fields: [territoryId], references: [id])

  @@unique([userId, territoryId])
}

// ============================================================
// TERRITORY
// ============================================================

model Territory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  zipCodes    String[]
  counties    String[]
  isActive    Boolean  @default(true)

  users      UserTerritory[]
  contacts   Contact[]
  properties Property[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// CORE ENTITIES
// ============================================================

enum ContactSource {
  ALN_DATA
  LUXOR
  MANUAL
  LEAD_FINDER
  ENRICHMENT
}

enum ContactStatus {
  RAW
  VALIDATED
  ENRICHED
  SCORED
  ACTIVE
  CONTACTED
  QUALIFIED
  DISQUALIFIED
  DO_NOT_CONTACT
}

model Contact {
  id        String @id @default(cuid())
  prefix    String?
  firstName String
  lastName  String
  suffix    String?
  fullName  String
  title     String?
  department String?

  email          String?
  emailSecondary String?
  phone          String?
  phoneSecondary String?
  phoneMobile    String?
  fax            String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zipCode      String?
  county       String?
  latitude     Float?
  longitude    Float?

  organizationId String?
  organization   Organization? @relation(fields: [organizationId], references: [id])
  properties     ContactProperty[]

  territoryId String?
  territory   Territory? @relation(fields: [territoryId], references: [id])

  source         ContactSource  @default(MANUAL)
  status         ContactStatus  @default(RAW)
  isGoldenRecord Boolean        @default(false)
  goldenRecordId String?

  dataQualityScore Float?
  lastValidatedAt  DateTime?
  lastEnrichedAt   DateTime?

  // Module 3: Enrichment (future)
  enrichmentBrief      String? @db.Text
  painTriggers         String[]
  personalizationHooks String[]

  // Module 4: Scoring (future)
  fitScore          Float?
  triggerScore      Float?
  reachabilityScore Float?
  compositeScore    Float?
  lastScoredAt      DateTime?

  // Module 5: Talk Tracks (future)
  talkTrackId String?

  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])
  sourceRowNumber Int?

  duplicateGroupId String?
  duplicateGroup   DuplicateGroup? @relation(fields: [duplicateGroupId], references: [id])

  validationResults ValidationResult[]
  notes             ContactNote[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@index([lastName, firstName])
  @@index([organizationId])
  @@index([territoryId])
  @@index([status])
  @@index([compositeScore(sort: Desc)])
  @@index([importBatchId])
  @@index([duplicateGroupId])
}

model ContactNote {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  content   String  @db.Text
  authorId  String?
  createdAt DateTime @default(now())
}

model ContactProperty {
  id         String  @id @default(cuid())
  contactId  String
  propertyId String
  role       String?
  isPrimary  Boolean @default(false)

  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([contactId, propertyId])
}

// ============================================================
// ORGANIZATION
// ============================================================

enum OrgType {
  PROPERTY_MANAGEMENT
  HOA
  CONDO_ASSOCIATION
  BUILDING_OWNER
  DEVELOPER
  INSURANCE
  OTHER
}

model Organization {
  id             String  @id @default(cuid())
  name           String
  nameNormalized String
  orgType        OrgType?
  website        String?
  domain         String?
  phone          String?
  fax            String?

  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  zipCode      String?

  employeeCount Int?
  yearFounded   Int?
  description   String? @db.Text

  contacts          Contact[]
  managedProperties OrgProperty[]

  source         ContactSource @default(MANUAL)
  isVerified     Boolean       @default(false)
  domainVerified Boolean       @default(false)

  // Module 3: Enrichment (future)
  enrichmentBrief String? @db.Text
  companyIntel    Json?

  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nameNormalized])
  @@index([domain])
}

model OrgProperty {
  id             String @id @default(cuid())
  organizationId String
  propertyId     String
  relationship   String?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  property     Property     @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([organizationId, propertyId])
}

// ============================================================
// PROPERTY
// ============================================================

enum PropertyType {
  LUXURY_CONDO
  HIGH_RISE
  MID_RISE
  LOW_RISE
  TOWNHOME
  SINGLE_FAMILY
  HOA_COMMUNITY
  COMMERCIAL
  MIXED_USE
  OTHER
}

model Property {
  id             String @id @default(cuid())
  name           String
  nameNormalized String

  propertyType PropertyType?

  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  zipCode      String
  county       String?
  latitude     Float?
  longitude    Float?

  unitCount      Int?
  yearBuilt      Int?
  floors         Int?
  totalSqFt      Int?
  floodZone      String?
  coastalExposure Boolean?
  lastRenovation  Int?
  riskLevel        String?
  opportunityScore Float?

  contacts      ContactProperty[]
  organizations OrgProperty[]

  territoryId String?
  territory   Territory? @relation(fields: [territoryId], references: [id])

  // Module 3 (future)
  enrichmentBrief String? @db.Text
  riskFactors     String[]

  // Module 6 (future)
  generatedPdfs GeneratedPdf[]

  importBatchId String?
  importBatch   ImportBatch? @relation(fields: [importBatchId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nameNormalized])
  @@index([zipCode])
  @@index([city, state])
  @@index([territoryId])
}

// ============================================================
// IMPORT + DATA PIPELINE
// ============================================================

enum ImportStatus {
  UPLOADED
  PARSING
  AWAITING_MAPPING
  MAPPING_COMPLETE
  PROCESSING
  DEDUPLICATING
  VALIDATING
  COMPLETED
  FAILED
  CANCELLED
}

model ImportBatch {
  id        String @id @default(cuid())
  fileName  String
  fileSize  Int
  mimeType  String
  filePath  String

  status        ImportStatus @default(UPLOADED)
  statusMessage String?
  errorMessage  String?

  source      ContactSource
  sourceLabel String?

  detectedColumns   Json?
  columnMapping     Json?
  mappingConfidence Json?

  totalRows        Int?
  processedRows    Int?
  skippedRows      Int?
  errorRows        Int?
  newContacts      Int?
  updatedContacts  Int?
  newOrganizations Int?
  newProperties    Int?
  duplicatesFound  Int?

  uploadedAt        DateTime  @default(now())
  parsingStartedAt  DateTime?
  processingStartedAt DateTime?
  completedAt       DateTime?

  uploadedById String
  uploadedBy   User @relation(fields: [uploadedById], references: [id])

  contacts     Contact[]
  organizations Organization[]
  properties   Property[]
  importRows   ImportRow[]
  importErrors ImportError[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([uploadedById])
}

model ImportRow {
  id            String      @id @default(cuid())
  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  rowNumber      Int
  rawData        Json
  normalizedData Json?
  status         String @default("pending")
  errorMessage   String?

  contactId      String?
  organizationId String?
  propertyId     String?

  createdAt DateTime @default(now())

  @@index([importBatchId])
  @@index([status])
}

model ImportError {
  id            String      @id @default(cuid())
  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  rowNumber Int?
  column    String?
  value     String?
  errorType String
  message   String

  createdAt DateTime @default(now())

  @@index([importBatchId])
}

// ============================================================
// DEDUPLICATION
// ============================================================

enum DuplicateStatus {
  PENDING
  AUTO_MERGED
  MANUALLY_MERGED
  DISMISSED
}

model DuplicateGroup {
  id           String          @id @default(cuid())
  status       DuplicateStatus @default(PENDING)
  confidence   Float
  matchReasons String[]

  goldenRecordId String?
  mergedById     String?

  contacts Contact[]

  createdAt  DateTime  @default(now())
  resolvedAt DateTime?

  @@index([status])
  @@index([confidence(sort: Desc)])
}

// ============================================================
// VALIDATION
// ============================================================

enum ValidationType {
  EMAIL_SYNTAX
  EMAIL_MX
  EMAIL_DISPOSABLE
  PHONE_FORMAT
  PHONE_TYPE
  ADDRESS_STANDARDIZED
  ADDRESS_GEOCODED
  DOMAIN_VERIFIED
}

enum ValidationStatus {
  VALID
  INVALID
  WARN
  UNCHECKED
  ERROR
}

model ValidationResult {
  id        String @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  type          ValidationType
  field         String
  originalValue String?
  status        ValidationStatus
  message       String?
  metadata      Json?

  checkedAt DateTime @default(now())

  @@index([contactId])
  @@index([type, status])
  @@unique([contactId, type, field])
}

// ============================================================
// FUTURE MODULE STUBS
// ============================================================

model TalkTrack {
  id       String  @id @default(cuid())
  name     String
  segment  String?
  category String
  content  Json
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GeneratedPdf {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id])
  templateId String?
  filePath   String
  metadata   Json?
  createdAt  DateTime @default(now())
}

model AuditLog {
  id         String @id @default(cuid())
  userId     String
  user       User   @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}
